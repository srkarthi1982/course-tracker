---
import AppShell from "../../layouts/AppShell.astro";
import { and, db, eq, Courses } from "astro:db";

const user = Astro.locals.user;
if (!user) return Astro.redirect("/");

const id = Number(Astro.params.id);
if (!Number.isFinite(id)) return Astro.redirect("/app");

const [course] = await db
  .select()
  .from(Courses)
  .where(and(eq(Courses.id, id), eq(Courses.userId, user.id)))
  .limit(1);

if (!course) return Astro.redirect("/app");
---

<AppShell title={`${course.title} · Course Tracker`} description="Course detail view">
  <main class="mx-auto max-w-3xl p-6 space-y-5">
    <a href="/app" class="text-sm text-slate-400 hover:text-white">← Back to workspace</a>
    <section class="rounded-xl border border-white/10 bg-white/5 p-5 space-y-3">
      <h1 class="text-2xl font-semibold text-white">{course.title}</h1>
      <p class="text-sm text-slate-300">{course.provider ?? "No provider"} · {course.subject ?? "No subject"}</p>
      <p class="text-sm text-slate-300">Status: <span class="capitalize">{course.status}</span></p>
      <p class="text-sm text-slate-300">Progress: {course.progressPercent}%</p>
      <p class="text-sm text-slate-300">Modules: {course.completedModules ?? 0} / {course.totalModules ?? "—"}</p>
      <p class="text-sm text-slate-300 whitespace-pre-wrap">{course.notes ?? "No notes yet."}</p>
      {course.url && (
        <a href={course.url} target="_blank" rel="noreferrer" class="text-sm text-cyan-300 hover:underline">Open course link</a>
      )}
    </section>
  </main>
</AppShell>
