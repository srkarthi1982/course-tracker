---
import AppShell from "../../layouts/AppShell.astro";
import { db, desc, eq, Courses } from "astro:db";

const user = Astro.locals.user;
if (!user) return Astro.redirect("/");

const courses = await db
  .select()
  .from(Courses)
  .where(eq(Courses.userId, user.id))
  .orderBy(desc(Courses.updatedAt));
---

<AppShell title="Course Tracker Workspace" description="Manage your courses and progress.">
  <main
    class="mx-auto max-w-6xl p-6 space-y-6"
    x-data
    x-init={`$store.courseTracker.init(${JSON.stringify(courses).replace(/`/g, "\\`")})`}
  >
    <header class="flex items-center justify-between gap-3">
      <div>
        <p class="text-sm text-slate-400">Welcome back</p>
        <h1 class="text-2xl font-semibold text-white">Your Course Workspace</h1>
      </div>
      <button class="rounded-lg bg-white/10 px-4 py-2 text-sm text-white" @click="$store.courseTracker.isCreateOpen=true">+ New course</button>
    </header>

    <section class="grid grid-cols-2 md:grid-cols-5 gap-3 text-sm">
      <div class="rounded-xl bg-white/5 p-3"><p>Total</p><p class="text-xl" x-text="$store.courseTracker.summary.total"></p></div>
      <div class="rounded-xl bg-white/5 p-3"><p>Active</p><p class="text-xl" x-text="$store.courseTracker.summary.active"></p></div>
      <div class="rounded-xl bg-white/5 p-3"><p>Paused</p><p class="text-xl" x-text="$store.courseTracker.summary.paused"></p></div>
      <div class="rounded-xl bg-white/5 p-3"><p>Completed</p><p class="text-xl" x-text="$store.courseTracker.summary.completed"></p></div>
      <div class="rounded-xl bg-white/5 p-3"><p>Archived</p><p class="text-xl" x-text="$store.courseTracker.summary.archived"></p></div>
    </section>

    <section class="rounded-xl bg-white/5 p-4 space-y-3">
      <div class="flex flex-wrap gap-2">
        <button @click="$store.courseTracker.setTab('overview')" class="px-3 py-1 rounded bg-white/10">Overview</button>
        <button @click="$store.courseTracker.setTab('courses')" class="px-3 py-1 rounded bg-white/10">Courses</button>
        <button @click="$store.courseTracker.setTab('completed')" class="px-3 py-1 rounded bg-white/10">Completed</button>
        <button @click="$store.courseTracker.setTab('archived')" class="px-3 py-1 rounded bg-white/10">Archived</button>
      </div>
      <input x-model="$store.courseTracker.search" placeholder="Search by title, provider, subject" class="w-full rounded-lg bg-slate-900 border border-white/10 px-3 py-2" />

      <template x-if="$store.courseTracker.flash.message">
        <p class="text-sm" :class="$store.courseTracker.flash.type === 'error' ? 'text-rose-300' : 'text-emerald-300'" x-text="$store.courseTracker.flash.message"></p>
      </template>

      <div class="space-y-2">
        <template x-for="course in $store.courseTracker.filteredCourses" :key="course.id">
          <article class="rounded-lg border border-white/10 p-3 flex items-start justify-between gap-3">
            <div>
              <a class="text-white font-medium hover:underline" :href="`/app/${course.id}`" x-text="course.title"></a>
              <p class="text-xs text-slate-400" x-text="[course.provider, course.subject].filter(Boolean).join(' · ') || 'No provider/subject yet'"></p>
              <p class="text-xs mt-1" x-text="`${course.progressPercent}% complete · ${course.status}`"></p>
            </div>
            <div class="flex gap-2 text-xs">
              <button class="px-2 py-1 rounded bg-white/10" @click="$store.courseTracker.openEdit(course)">Edit</button>
              <button class="px-2 py-1 rounded bg-white/10" @click="$store.courseTracker.markCompleted(course.id)" x-show="course.status!=='completed'">Complete</button>
              <button class="px-2 py-1 rounded bg-white/10" @click="$store.courseTracker.archive(course.id)" x-show="course.status!=='archived'">Archive</button>
              <button class="px-2 py-1 rounded bg-white/10" @click="$store.courseTracker.restore(course.id)" x-show="course.status==='archived'">Restore</button>
            </div>
          </article>
        </template>
        <p class="text-sm text-slate-400" x-show="$store.courseTracker.filteredCourses.length===0">No courses match this view yet.</p>
      </div>
    </section>

    <section x-show="$store.courseTracker.isCreateOpen" class="fixed inset-0 bg-black/50 p-6">
      <div class="mx-auto max-w-xl rounded-xl bg-slate-950 border border-white/10 p-4 space-y-3">
        <h2 class="text-lg">Create course</h2>
        <form class="grid gap-2" @submit.prevent="$store.courseTracker.createCourse({title:$event.target.title.value,provider:$event.target.provider.value,subject:$event.target.subject.value,notes:$event.target.notes.value,progressPercent:Number($event.target.progressPercent.value||0),totalModules:$event.target.totalModules.value?Number($event.target.totalModules.value):undefined,completedModules:$event.target.completedModules.value?Number($event.target.completedModules.value):undefined})">
          <input name="title" required placeholder="Title" class="rounded bg-white/5 px-3 py-2" />
          <input name="provider" placeholder="Provider" class="rounded bg-white/5 px-3 py-2" />
          <input name="subject" placeholder="Subject" class="rounded bg-white/5 px-3 py-2" />
          <textarea name="notes" placeholder="Notes" class="rounded bg-white/5 px-3 py-2"></textarea>
          <div class="grid grid-cols-3 gap-2">
            <input name="progressPercent" type="number" min="0" max="100" placeholder="Progress %" class="rounded bg-white/5 px-3 py-2" />
            <input name="totalModules" type="number" min="0" placeholder="Total modules" class="rounded bg-white/5 px-3 py-2" />
            <input name="completedModules" type="number" min="0" placeholder="Done modules" class="rounded bg-white/5 px-3 py-2" />
          </div>
          <div class="flex justify-end gap-2">
            <button type="button" @click="$store.courseTracker.isCreateOpen=false" class="px-3 py-2 rounded bg-white/10">Cancel</button>
            <button type="submit" class="px-3 py-2 rounded bg-emerald-600">Create</button>
          </div>
        </form>
      </div>
    </section>

    <section x-show="$store.courseTracker.isEditOpen && $store.courseTracker.activeCourse" class="fixed inset-0 bg-black/50 p-6">
      <div class="mx-auto max-w-xl rounded-xl bg-slate-950 border border-white/10 p-4 space-y-3">
        <h2 class="text-lg">Edit course</h2>
        <form class="grid gap-2" @submit.prevent="$store.courseTracker.updateCourse({id:$store.courseTracker.activeCourse.id,title:$event.target.title.value,provider:$event.target.provider.value,subject:$event.target.subject.value,notes:$event.target.notes.value,status:$event.target.status.value,progressPercent:Number($event.target.progressPercent.value||0),totalModules:$event.target.totalModules.value?Number($event.target.totalModules.value):null,completedModules:$event.target.completedModules.value?Number($event.target.completedModules.value):null})">
          <input name="title" required :value="$store.courseTracker.activeCourse?.title" class="rounded bg-white/5 px-3 py-2" />
          <input name="provider" :value="$store.courseTracker.activeCourse?.provider || ''" class="rounded bg-white/5 px-3 py-2" />
          <input name="subject" :value="$store.courseTracker.activeCourse?.subject || ''" class="rounded bg-white/5 px-3 py-2" />
          <textarea name="notes" class="rounded bg-white/5 px-3 py-2" x-text="$store.courseTracker.activeCourse?.notes || ''"></textarea>
          <select name="status" class="rounded bg-white/5 px-3 py-2">
            <option value="active">Active</option><option value="paused">Paused</option><option value="completed">Completed</option><option value="archived">Archived</option>
          </select>
          <div class="grid grid-cols-3 gap-2">
            <input name="progressPercent" type="number" min="0" max="100" :value="$store.courseTracker.activeCourse?.progressPercent" class="rounded bg-white/5 px-3 py-2" />
            <input name="totalModules" type="number" min="0" :value="$store.courseTracker.activeCourse?.totalModules || ''" class="rounded bg-white/5 px-3 py-2" />
            <input name="completedModules" type="number" min="0" :value="$store.courseTracker.activeCourse?.completedModules || ''" class="rounded bg-white/5 px-3 py-2" />
          </div>
          <div class="flex justify-end gap-2">
            <button type="button" @click="$store.courseTracker.isEditOpen=false" class="px-3 py-2 rounded bg-white/10">Cancel</button>
            <button type="submit" class="px-3 py-2 rounded bg-emerald-600">Save</button>
          </div>
        </form>
      </div>
    </section>
  </main>
</AppShell>
