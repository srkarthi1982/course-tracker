---
import AppShell from "../layouts/AppShell.astro";
import { AvButton, AvContainer } from "@ansiversa/components";
---

<AppShell title="Course Tracker" description="Plan, track, and finish courses with clarity.">
  <section class="av-hero">
    <AvContainer size="narrow" className="av-hero__content--narrow">
      <div class="av-hero__content">
        <div class="av-kicker"><span>Ansiversa · Learning OS</span></div>
        <h1 class="av-gradient-text">Finish more courses with less friction.</h1>
        <p>
          Course Tracker gives you a clean command center for every class, cohort, and self-paced
          program—so progress stays visible every day.
        </p>
      </div>
      <div class="av-cta-row">
        <AvButton href="/app">Open workspace</AvButton>
      </div>
    </AvContainer>
  </section>
</AppShell>
